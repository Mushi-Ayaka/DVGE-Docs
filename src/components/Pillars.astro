---
import IconCpu from './icons/IconCpu.astro';
import IconShield from './icons/IconShield.astro';
import IconZap from './icons/IconZap.astro';

const pillars = [
  {
    title: "Knowledge Bridge (v5.6)",
    description: "Inyección nativa de reglas para IAs. Genera PDFs maestros para que Claude, Gemini o GPT entiendan el motor y generen plugins perfectos al primer intento.",
    color: "#E44C30",
    icon: IconZap
  },
  {
    title: "Auto-Fetch Deps",
    description: "Independencia total. El motor detecta y descarga automáticamente Chromium y FFmpeg en el primer inicio, garantizando el renderizado sin instalaciones previas.",
    color: "#00f2ff",
    icon: IconCpu
  },
  {
    title: "Sandbox de Seguridad",
    description: "Caja de arena inquebrantable. Ejecuta plugins de la comunidad con total confianza mediante Shadow DOM y aislamiento de procesos nativo.",
    color: "#ffd700",
    icon: IconShield
  },
  {
    title: "Transparencia Pro",
    description: "Exportación nativa en ProRes 4444 con canal alfa puro. Estabilidad garantizada desde el fotograma 0 para los pipelines de broadcast más exigentes.",
    color: "#a855f7",
    icon: IconZap
  }
];
---

<section class="pillars-section">
  <div class="section-header">
    <h2 class="section-title">Construido para <span class="text-gradient">Confiabilidad</span></h2>
    <p class="section-subtitle">Los gráficos de transmisión profesional requieren más que solo animación. Requieren excelencia en ingeniería.</p>
  </div>

  <div class="pillars-grid">
    {pillars.map((pillar) => (
      <div class="pillar-card">
        <div class="pillar-icon" style={`--icon-color: ${pillar.color}`}>
          <pillar.icon color={pillar.color} size={32} />
        </div>
        <h3>{pillar.title}</h3>
        <p>{pillar.description}</p>
      </div>
    ))}
  </div>
</section>


<style>
  .pillars-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 8rem 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 1.2rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .pillar-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
    backdrop-filter: var(--glass-blur);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .pillar-card:hover {
    transform: translateY(-10px);
    border-color: rgba(228, 76, 48, 0.4);
  }

  .pillar-icon {
    width: 64px;
    height: 64px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    color: var(--icon-color);
    box-shadow: 0 0 20px rgba(0,0,0,0.2);
  }

  .pillar-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .pillar-card p {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  @media (max-width: 968px) {
    .pillars-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
