---
import '../styles/variables.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
}

const {
	title,
	description = "DVGE es una aplicación de escritorio para Windows que genera overlays, lower thirds y gráficos broadcast animados con exportación ProRes 4444 + Alpha para DaVinci Resolve, Premiere Pro y After Effects. Open Source MIT.",
	ogImage = "https://mushi-ayaka.github.io/DVGE-Docs/icon_highlight.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://mushi-ayaka.github.io");
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalURL} />
		<link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon.png`} />

		<title>{title}</title>

		<!-- Keywords explícitas para diferenciación semántica -->
		<meta name="keywords" content="broadcast graphics software, lower thirds Windows, overlays DaVinci Resolve, gráficos broadcast, lower thirds animados, overlay broadcast, ProRes 4444 Windows, Electron broadcast app, DVGE, Dynamic Vector Graphics Engine" />
		<meta name="application-name" content="DVGE" />
		<meta name="category" content="Broadcast Graphics Software" />

		<!-- Open Graph -->
		<meta property="og:type"        content="website" />
		<meta property="og:locale"      content="es_ES" />
		<meta property="og:url"         content={canonicalURL} />
		<meta property="og:title"       content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image"       content={ogImage} />
		<meta property="og:site_name"   content="DVGE — Dynamic Vector Graphics Engine" />

		<!-- Twitter Card -->
		<meta name="twitter:card"        content="summary_large_image" />
		<meta name="twitter:title"       content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image"       content={ogImage} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@700;800&display=swap" rel="stylesheet" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		/* Additional global styles if needed */
	}
</style>
