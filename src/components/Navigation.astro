---
import icon from "../assets/icon.png";
const base = import.meta.env.BASE_URL;
const downloadUrl = "https://github.com/Mushi-Ayaka/Dynamic-Vector-Graphics-Engine--DVGE-/releases/download/v5.6.0/DVGE-Setup-5.6.0.exe";
---

<nav class="nav-container">
  <div class="nav-content">
    <a href={base} class="logo">
      <img src={icon.src} alt="Logo de DVGE" width="32" height="32" />
      <span>DVGE</span>
    </a>

    <button class="mobile-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-links">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path class="menu-icon" d="M3 12h18M3 6h18M3 18h18"></path>
        <path class="close-icon" d="M18 6L6 18M6 6l12 12" style="display: none;"></path>
      </svg>
    </button>

    <div class="nav-links" id="nav-links">
      <div class="dropdown">
        <button class="dropbtn" aria-expanded="false" aria-haspopup="true">
          Motor
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="dropdown-content" role="menu">
          <a href={`${base}engine/architecture/`} role="menuitem">Arquitectura Central</a>
          <a href={`${base}engine/performance/`} role="menuitem">Rendimiento</a>
          <a href={`${base}engine/benchmarks/`} role="menuitem">Benchmarks</a>
          <a href={`${base}engine/roadmap/`} role="menuitem">Hoja de Ruta</a>
        </div>
      </div>

      <div class="dropdown">
        <button class="dropbtn" aria-expanded="false" aria-haspopup="true">
          Ecosistema
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="dropdown-content" role="menu">
          <a href={`${base}ecosystem/community/`} role="menuitem">Comunidad</a>
          <a href={`${base}ecosystem/repository/`} role="menuitem">Galería de Plugins</a>
          <a href={`${base}ecosystem/api/`} role="menuitem">API de Extensión</a>
        </div>
      </div>

      <div class="dropdown">
        <button class="dropbtn" aria-expanded="false" aria-haspopup="true">
          Desarrollo
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="dropdown-content" role="menu">
          <a href={`${base}development/quick-start/`} role="menuitem">Guía de Inicio</a>
          <a href={`${base}development/ai-guide/`} role="menuitem">Plugins con IA</a>
          <a href={`${base}development/contributing/`} role="menuitem">Contribuir</a>
        </div>
      </div>

      <div class="dropdown">
        <button class="dropbtn" aria-expanded="false" aria-haspopup="true">
          Proyecto
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="dropdown-content" role="menu">
          <a href={`${base}about/user-manual/`} role="menuitem">Manual de Usuario</a>
          <a href={`${base}about/changelog/`} role="menuitem">Changelog</a>
          <a href={`${base}about/vision/`} role="menuitem">La Visión</a>
          <a href={`${base}about/transparency/`} role="menuitem">Transparencia</a>
          <a href={`${base}about/branding/`} role="menuitem">Identidad Visual</a>
        </div>
      </div>

      <div class="dropdown">
        <button class="dropbtn" aria-expanded="false" aria-haspopup="true">
          Acerca de
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg>
        </button>
        <div class="dropdown-content" role="menu">
          <a href={`${base}about/me/`} role="menuitem">El Desarrollador</a>
          <a href={`${base}about/credits/`} role="menuitem">Créditos</a>
          <a href={`${base}about/license/`} role="menuitem">Licencia</a>
        </div>
      </div>

      <a href="https://github.com/Mushi-Ayaka/Dynamic-Vector-Graphics-Engine--DVGE-" target="_blank" rel="noopener" class="github-link" aria-label="Repositorio en GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
          <path d="M9 18c-4.51 2-5-2-7-2"></path>
        </svg>
      </a>

      <a href={downloadUrl} class="nav-cta" aria-label="Descargar DVGE v5.6.0">
        Descargar
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile toggle
  const toggle = document.querySelector(".mobile-toggle") as HTMLButtonElement;
  const navLinks = document.querySelector(".nav-links");
  const menuIcon = document.querySelector(".menu-icon") as HTMLElement;
  const closeIcon = document.querySelector(".close-icon") as HTMLElement;

  toggle?.addEventListener("click", () => {
    const isActive = navLinks?.classList.toggle("active");
    toggle.setAttribute("aria-expanded", String(isActive));
    toggle.setAttribute("aria-label", isActive ? "Cerrar menú" : "Abrir menú");
    if (menuIcon && closeIcon) {
      menuIcon.style.display = isActive ? "none" : "block";
      closeIcon.style.display = isActive ? "block" : "none";
    }
  });

  // Dropdowns: hover en desktop, click en móvil/touch
  document.querySelectorAll(".dropdown").forEach((dropdown) => {
    const btn = dropdown.querySelector(".dropbtn") as HTMLButtonElement;
    const content = dropdown.querySelector(".dropdown-content") as HTMLElement;

    btn?.addEventListener("click", (e) => {
      // Solo activar click en móvil (cuando el toggle es visible)
      if (window.innerWidth <= 960) {
        e.preventDefault();
        const isOpen = content.style.maxHeight && content.style.maxHeight !== "0px";
        // Cerrar todos los demás
        document.querySelectorAll(".dropdown-content").forEach((el) => {
          (el as HTMLElement).style.maxHeight = "0px";
        });
        document.querySelectorAll(".dropbtn").forEach((b) => {
          (b as HTMLButtonElement).setAttribute("aria-expanded", "false");
        });
        if (!isOpen) {
          content.style.maxHeight = content.scrollHeight + "px";
          btn.setAttribute("aria-expanded", "true");
        }
      }
    });

    // Keyboard: Enter/Space abre el dropdown
    btn?.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        btn.click();
      }
      if (e.key === "Escape") {
        content.style.maxHeight = "0px";
        btn.setAttribute("aria-expanded", "false");
        btn.focus();
      }
    });
  });

  // Cerrar menú móvil al hacer click fuera
  document.addEventListener("click", (e) => {
    if (!toggle?.contains(e.target as Node) && !navLinks?.contains(e.target as Node)) {
      navLinks?.classList.remove("active");
      toggle?.setAttribute("aria-expanded", "false");
      if (menuIcon && closeIcon) {
        menuIcon.style.display = "block";
        closeIcon.style.display = "none";
      }
    }
  });
</script>

<style>
  .nav-container {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 0.75rem 1.5rem;
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--glass-border);
    background: rgba(5, 5, 5, 0.8);
  }

  .nav-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: "Outfit", sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text);
    text-decoration: none;
    z-index: 1001;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .mobile-toggle {
    display: none;
    background: transparent;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.5rem;
    z-index: 1001;
  }
  .mobile-toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    border-radius: 4px;
  }

  .dropdown {
    position: relative;
    display: inline-block;
  }

  .dropbtn {
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    font-family: "Inter", sans-serif;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0;
    transition: color 0.2s ease;
  }
  .dropbtn:focus-visible {
    outline: 2px solid var(--color-primary);
    border-radius: 4px;
  }

  .dropdown:hover .dropbtn,
  .dropbtn[aria-expanded="true"] {
    color: var(--color-primary);
  }

  .dropdown-content {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 8px; /* espacio visual sin romper el hover */
    background-color: #0d0d0d;
    min-width: 200px;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.8);
    z-index: 101;
    overflow: hidden;
  }

  /* Cubre el gap entre botón y panel para que el hover no se interrumpa */
  .dropdown::before {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 8px;
    z-index: 100;
  }

  .dropdown-content a {
    color: var(--color-text-muted);
    padding: 10px 20px;
    text-decoration: none;
    display: block;
    font-size: 0.85rem;
    transition: all 0.2s ease;
  }
  .dropdown-content a:hover,
  .dropdown-content a:focus-visible {
    background-color: rgba(228, 76, 48, 0.1);
    color: var(--color-primary);
    padding-left: 25px;
    outline: none;
  }

  .dropdown:hover .dropdown-content {
    display: block;
    animation: fadeIn 0.15s ease;
  }

  .github-link {
    display: flex;
    align-items: center;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }
  .github-link:hover { color: var(--color-primary); }
  .github-link:focus-visible {
    outline: 2px solid var(--color-primary);
    border-radius: 4px;
  }

  .nav-cta {
    background: var(--color-primary);
    color: white;
    padding: 0.45rem 1rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }
  .nav-cta:hover {
    background: var(--color-primary-hover, #f05a3e);
    transform: translateY(-1px);
  }
  .nav-cta:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translate(-50%, -6px); }
    to   { opacity: 1; transform: translate(-50%, 0); }
  }

  @media (max-width: 960px) {
    .mobile-toggle { display: block; }

    .nav-links {
      position: fixed;
      top: 0;
      right: -100%;
      width: 80%;
      max-width: 350px;
      height: 100vh;
      background: #050505;
      flex-direction: column;
      align-items: flex-start;
      padding: 6rem 2rem 2rem;
      transition: right 0.3s ease-in-out;
      border-left: 1px solid var(--glass-border);
      gap: 0;
      overflow-y: auto;
    }
    .nav-links.active { right: 0; }

    .dropdown { width: 100%; }

    .dropbtn {
      width: 100%;
      justify-content: space-between;
      font-size: 1.1rem;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .dropdown-content {
      position: static;
      transform: none;
      display: block;
      background: transparent;
      border: none;
      box-shadow: none;
      padding-left: 1rem;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out;
      animation: none;
    }

    .dropdown:hover .dropdown-content {
      /* En móvil el hover no aplica — se maneja por JS */
      display: block;
      max-height: 0;
    }

    .dropdown-content a { padding: 0.75rem 0; }

    .github-link { margin-top: 1rem; }

    .nav-cta {
      margin-top: 1.5rem;
      width: 100%;
      text-align: center;
      padding: 0.75rem;
    }
  }
</style>
