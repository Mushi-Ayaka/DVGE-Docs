---
import icon from "../assets/icon.png";
const base = import.meta.env.BASE_URL;
---

<nav class="nav-container">
  <div class="nav-content">
    <a href={base} class="logo">
      <img src={icon.src} alt="Logo de DVGE" width="32" height="32" />
      <span>DVGE</span>
    </a>

    <button class="mobile-toggle" aria-label="Toggle Menu">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path class="menu-icon" d="M3 12h18M3 6h18M3 18h18"></path>
        <path class="close-icon" d="M18 6L6 18M6 6l12 12" style="display: none;"
        ></path>
      </svg>
    </button>

    <div class="nav-links">
      <div class="dropdown">
        <a href={`${base}engine/architecture/`} class="dropbtn"
          >Motor <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg
          ></a
        >
        <div class="dropdown-content">
          <a href={`${base}engine/architecture/`}>Arquitectura Central</a>
          <a href={`${base}engine/performance/`}>Rendimiento</a>
          <a href={`${base}engine/benchmarks/`}>Benchmarks</a>
          <a href={`${base}engine/roadmap/`}>Hoja de Ruta (Roadmap)</a>
        </div>
      </div>

      <div class="dropdown">
        <a href={`${base}ecosystem/community/`} class="dropbtn"
          >Ecosistema <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg
          ></a
        >
        <div class="dropdown-content">
          <a href={`${base}ecosystem/community/`}>Comunidad y Taxonomía</a>
          <a href={`${base}ecosystem/repository/`}>Galería de Plugins</a>
          <a href={`${base}ecosystem/api/`}>API de Extensión</a>
        </div>
      </div>

      <div class="dropdown">
        <a href={`${base}development/quick-start/`} class="dropbtn"
          >Desarrollo <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg
          ></a
        >
        <div class="dropdown-content">
          <a href={`${base}development/quick-start/`}>Guía de Inicio</a>
          <a href={`${base}development/ai-guide/`}>Plugins con IA</a>
          <a href={`${base}development/contributing/`}>Contribuir</a>
        </div>
      </div>

      <div class="dropdown">
        <a href={`${base}about/vision/`} class="dropbtn"
          >Proyecto <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg
          ></a
        >
        <div class="dropdown-content">
          <a href={`${base}about/user-manual/`}>Manual de Usuario</a>
          <a href={`${base}about/changelog/`}>Changelog</a>
          <a href={`${base}about/transparency/`}>Transparencia Real</a>
          <a href={`${base}about/identity/`}>Identidad Visual</a>
        </div>
      </div>

      <div class="dropdown">
        <a href={`${base}about/vision/`} class="dropbtn"
          >A cerca de <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg
          ></a
        >
        <div class="dropdown-content">
          <a href={`${base}about/me/`}>El Desarrollador</a>
          <a href={`${base}about/vision/`}>La Visión</a>
          <a href={`${base}about/credits/`}>Créditos</a>
          <a href={`${base}about/license/`}>Licencia</a>
          <a href={`${base}about/privacy/`}>Privacidad</a>
          <a href={`${base}about/terms/`}>Términos</a>
        </div>
      </div>

      <a
        href="https://github.com/Mushi-Ayaka/Dynamic-Vector-Graphics-Engine--DVGE-"
        target="_blank"
        class="github-link"
        aria-label="GitHub"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
        >
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.querySelector(".mobile-toggle");
  const navLinks = document.querySelector(".nav-links");
  const menuIcon = document.querySelector(".menu-icon");
  const closeIcon = document.querySelector(".close-icon");

  toggle?.addEventListener("click", () => {
    navLinks?.classList.toggle("active");
    const isActive = navLinks?.classList.contains("active");

    if (menuIcon && closeIcon) {
      (menuIcon as HTMLElement).style.display = isActive ? "none" : "block";
      (closeIcon as HTMLElement).style.display = isActive ? "block" : "none";
    }
  });
</script>

<style>
  .nav-container {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 0.75rem 1.5rem;
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--glass-border);
    background: rgba(5, 5, 5, 0.8);
  }

  .nav-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: "Outfit", sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text);
    text-decoration: none;
    z-index: 1001;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .mobile-toggle {
    display: none;
    background: transparent;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.5rem;
    z-index: 1001;
  }

  /* Dropdown Styles */
  .dropdown {
    position: relative;
    display: inline-block;
  }

  .dropbtn {
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    font-family: "Inter", sans-serif;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .dropdown:hover .dropbtn {
    color: var(--color-primary);
  }

  .dropdown-content {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background-color: #0d0d0d;
    min-width: 220px;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    box-shadow: 0px 8px 32px 0px rgba(0, 0, 0, 0.8);
    z-index: 101;
    padding: 0.5rem 0;
    overflow: hidden;
  }

  .dropdown-content a {
    color: var(--color-text-muted);
    padding: 10px 20px;
    text-decoration: none;
    display: block;
    font-size: 0.85rem;
    transition: all 0.2s ease;
  }

  .dropdown-content a:hover {
    background-color: rgba(228, 76, 48, 0.1);
    color: var(--color-primary);
    padding-left: 25px;
  }

  .dropdown:hover .dropdown-content {
    display: block;
    animation: fadeIn 0.2s ease;
  }

  .github-link {
    display: flex;
    align-items: center;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .github-link:hover {
    color: var(--color-primary);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translate(-50%, -10px);
    }
    to {
      opacity: 1;
      transform: translate(-50%, 0);
    }
  }

  @media (max-width: 960px) {
    .mobile-toggle {
      display: block;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: -100%;
      width: 80%;
      max-width: 350px;
      height: 100vh;
      background: #050505;
      flex-direction: column;
      align-items: flex-start;
      padding: 6rem 2rem;
      transition: 0.3s ease-in-out;
      border-left: 1px solid var(--glass-border);
      gap: 1rem;
      overflow-y: auto;
    }

    .nav-links.active {
      right: 0;
    }

    .dropdown {
      width: 100%;
    }

    .dropbtn {
      width: 100%;
      justify-content: space-between;
      font-size: 1.1rem;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .dropdown-content {
      position: static;
      transform: none;
      display: block;
      background: transparent;
      border: none;
      box-shadow: none;
      padding-left: 1rem;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out;
    }

    .dropdown:hover .dropdown-content {
      max-height: 500px;
    }

    .dropdown-content a {
      padding: 0.75rem 0;
    }

    .github-link {
      margin-top: 1rem;
    }
  }
</style>
