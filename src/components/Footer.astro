<style>
  .footer {
    border-top: 1px solid var(--glass-border);
    background: var(--color-surface);
    padding: 6rem 2rem 2rem;
    margin-top: 4rem;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
  }

  .footer-tagline {
    color: var(--color-text-muted);
    max-width: 300px;
    margin-bottom: 2rem;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
  }

  .social-links a {
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .social-links a:hover {
    color: var(--color-primary);
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .nav-column h4 {
    margin-bottom: 1.5rem;
    font-size: 1rem;
    color: var(--color-text);
  }

  .nav-column a {
    display: block;
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .nav-column a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  @media (max-width: 968px) {
    .footer-content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-info {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
